{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Sync",
  "version": "0.1.0",
  "identifier": "com.claudesync.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Sync",
        "width": 420,
        "height": 640,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
